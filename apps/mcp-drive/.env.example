# mcp-drive — variáveis específicas
# Outras (GOOGLE_SERVICE_ACCOUNT_JSON) são compartilhadas com apps/ai e ficam no .env raiz.

# ID da Drive compartilhada raiz (default: 107_PROJETOS 2026 da Thórus)
THORUS_DRIVE_ROOT_ID=0AGS3i6FJiluJUk9PVA

# TTL do cache em segundos (default: 300 = 5 min)
MCP_DRIVE_CACHE_TTL_SECONDS=300

# Nível de log no stderr (DEBUG | INFO | WARNING | ERROR | CRITICAL)
MCP_DRIVE_LOG_LEVEL=INFO
