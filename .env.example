# =============================================================================
# Oráculo Thórus — Variáveis de ambiente (template)
# Copie este arquivo pra .env e preencha com os valores reais.
# Nunca commite .env com segredos.
# =============================================================================

# -----------------------------------------------------------------------------
# Deploy / runtime
# -----------------------------------------------------------------------------
# Ambiente de execução. Em "production" (Railway), próximas fases ativam
# logging estruturado, health checks específicos e CORS estrito.
ENV=development

# Nível mínimo de log emitido pelo root logger. Aceita uppercase apenas:
# DEBUG, INFO, WARNING, ERROR, CRITICAL. Default INFO atende prod;
# DEBUG é útil em dev pra ver request-by-request.
LOG_LEVEL=INFO

# MCP Drive transport. Valores: stdio | streamable-http | sse.
#   stdio (dev default): Thor spawna `python -m mcp_drive` como
#     subprocess e troca JSON-RPC via stdin/stdout.
#   streamable-http (prod): mcp-drive sobe como serviço HTTP separado
#     (Railway etc.); Thor chama via URL com header X-MCP-Token.
#   sse: fallback se streamable-http indisponível na infra.
MCP_DRIVE_TRANSPORT=stdio

# URL do mcp-drive HTTP (lado cliente — apps/api+ai). Path /mcp é o
# default do FastMCP pra streamable-http.
MCP_DRIVE_URL=http://127.0.0.1:8001/mcp

# Token compartilhado entre Thor e mcp-drive. OBRIGATÓRIO em transport
# != stdio: mcp-drive recusa boot se vazio. Gere com:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_DRIVE_AUTH_TOKEN=

# Bind do servidor HTTP do mcp-drive (lado servidor). Em prod, host
# 0.0.0.0 pra escutar em todas interfaces do container.
MCP_DRIVE_HOST=127.0.0.1
MCP_DRIVE_PORT=8001

# CSV de origins aceitas pelo CORS do FastAPI. Em dev mantém o frontend
# Next.js local. Em prod: ALLOWED_ORIGINS=https://thor.thorus.com.br
# (múltiplos: separe com vírgula, sem espaço entre).
ALLOWED_ORIGINS=http://localhost:3000

# Diretório onde o pipeline Document AI lê arquivos pra ingestão.
# Default Linux/container; sobrescreva em dev Windows pra C:/... .
DOCUMENT_AI_INCOMING_DIR=/var/oraculo-thorus/incoming

# Domínio do Workspace Google da Thórus. Auth do backend rejeita
# qualquer outro domínio. Frontend (apps/web/middleware.ts) tem o
# mesmo valor hardcoded.
ALLOWED_EMAIL_DOMAIN=thorusengenharia.com.br

# -----------------------------------------------------------------------------
# LLM (acesso SEMPRE via LiteLLM — não importar SDKs direto no código)
# -----------------------------------------------------------------------------
LLM_PROVIDER=groq
LLM_MODEL_FAST=groq/llama-3.3-70b-versatile
LLM_MODEL_SMART=groq/llama-3.3-70b-versatile
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# Embeddings (também via LiteLLM)
# Se trocar de provedor, REINDEXAR tudo (dim pode mudar).
# -----------------------------------------------------------------------------
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Supabase (Postgres + pgvector + Auth + Storage)
#
# Novo formato de chaves de API (substitui as antigas anon / service_role JWT):
#   - sb_publishable_xxx → pública, segura pra expor no frontend.
#                          Substitui a antiga SUPABASE_ANON_KEY.
#   - sb_secret_xxx      → SECRETA, dá acesso total e bypassa RLS.
#                          Substitui a antiga SUPABASE_SERVICE_ROLE_KEY.
#                          NUNCA expor no frontend, em logs, em commits ou em URLs.
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres

# Conexão read-only pra tool query_database do Thor. Usa a role
# thor_query_ro (criada em supabase/migrations/20260505160000_add_thor_query_ro_role.sql).
# Após aplicar a migration, gere uma senha forte e habilite LOGIN:
#     ALTER ROLE thor_query_ro WITH LOGIN PASSWORD '<senha-aleatória-forte>';
# Use o pooler de transação (porta 6543) pro Supabase Cloud:
#     postgresql://thor_query_ro:<senha>@<host>:6543/postgres
# Vazio = tool indisponível pro Thor (mesmo pra admin).
DATABASE_URL_QUERY_RO=

# JWT verification — preencha PELO MENOS um dos dois.
# - SUPABASE_JWT_SECRET: secret HS256 do projeto (Settings → API → JWT secret)
# - SUPABASE_JWKS_URL: URL pública pra validação assimétrica (RS256/ES256)
SUPABASE_JWT_SECRET=
SUPABASE_JWKS_URL=

# Domain restriction pra auth (defesa em profundidade — também há check no Supabase trigger)
ALLOWED_EMAIL_DOMAIN=thorus.com.br

# -----------------------------------------------------------------------------
# Langfuse (observabilidade — toda chamada de LLM rastreada)
# -----------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3030

# -----------------------------------------------------------------------------
# Google (OAuth pra login restrito ao domínio Thórus + Service Account pra Sheets)
# -----------------------------------------------------------------------------
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_SERVICE_ACCOUNT_JSON=

# -----------------------------------------------------------------------------
# Document AI — pasta local onde clientes deixam documentos (PDF/DOCX/XLSX/CSV/TXT)
# Subpasta por projeto: <DIR>/<numero_projeto>/<arquivos>
# -----------------------------------------------------------------------------
DOCUMENT_AI_INCOMING_DIR=C:/oraculo-thorus/incoming

# -----------------------------------------------------------------------------
# MCP Drive — awareness READ-ONLY do Google Drive Thórus pro Thor.
# Service account é a mesma do GOOGLE_SERVICE_ACCOUNT_JSON acima.
# -----------------------------------------------------------------------------
THORUS_DRIVE_ROOT_ID=0AGS3i6FJiluJUk9PVA
MCP_DRIVE_CACHE_TTL_SECONDS=300
MCP_DRIVE_LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Frontend Next.js (público — prefixadas com NEXT_PUBLIC_)
# Apenas a publishable key vai pra cá. A secret key NUNCA pode aparecer
# em variável NEXT_PUBLIC_* — o Next.js inlinea isso no bundle do browser.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_AI_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
